{
  "name": "@sugi-cmms/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @sugi-cmms/shared build && vite --host 0.0.0.0",
    "build": "pnpm --filter @sugi-cmms/shared build && tsc -p tsconfig.json && vite build",
    "typecheck": "pnpm --filter @sugi-cmms/shared build && tsc -p tsconfig.json --noEmit",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@sugi-cmms/shared": "workspace:*",
    "@vitejs/plugin-react": "^4.6.0",
    "@zxing/browser": "^0.2.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.8.3"
  }
}
