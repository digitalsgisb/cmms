{
  "name": "@sugi-cmms/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @sugi-cmms/shared build && tsx watch src/server.ts",
    "build": "pnpm --filter @sugi-cmms/shared build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @sugi-cmms/shared build && tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@sugi-cmms/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
